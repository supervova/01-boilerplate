{
  "color": {

    "base": {
      "h-red":          { "value": "0" },
      "h-yellow":       { "value": "60" },
      "h-green":        { "value": "120" },
      "h-blue":         { "value": "210" },
      "h-magenta":      { "value": "300" },

      "h":              { "value": "{color.base.h-blue.value}" },
      "s":              { "value": "80%" },
      "s-neutral":      { "value": "10%" }
    },

    "neutral": {
      "100":            { "value": "hsl({color.base.h.value}, {color.base.s-neutral.value}, 92%)" },
      "500":            { "value": "hsl({color.base.h.value}, {color.base.s-neutral.value}, 50%)" },
      "900":            { "value": "hsl({color.base.h.value}, {color.base.s.value}, 10%)" }
    },

    "brand": {
      "100":            { "value": "hsl({color.base.h.value}, {color.base.s.value}), 92%" },
      "default":        { "value": "{color.brand.600.value}" }
    },

    "background": {
      "base":           { "value": "{color.neutral.100.value}" },
      "success":        { "value": "hsl({color.base.h-green.value}, {color.base.s.value}, 86%)" }
    },

    "ink": {
      "base":           { "value": "{color.neutral.800.value}" },
      "success":        { "value": "hsl({color.base.h-green.value}, {color.base.s.value}, 86%)" },
      "inverted": {
        "max":          { "value": "#fff" },
        "base":         { "value": "hsl(0 0% 0% / .87)" }
      }
    },

    "icon":             { "value": "{color.neutral.100.value}" },
    "border":           { "value": "{color.neutral.100.value}" },
    "border-inverted":  { "value": "{color.neutral.100.value}" }
  },

  "size": {
    "half":             { "value": "4px" },
    "1":                { "value": "8px" },
    "1p5":              { "value": "12px" },
    "2":                { "value": "16px" },
    "2p5":              { "value": "20px" },

    "width": {
      "screen": {
        "desktop-xl":   { "value": "1920px" },
        "desktop-xxl":  { "value": "2560px" }
      }
    }
  },

  "text": {
    "base": {
      "font-size":      { "value": "16px" },
      "line-height":    { "value": "1.5" },
      "padding-top":    { "value": "6px" },
      "padding-bottom": { "value": "2px" }
    },

    // I don't like this solution. Let's break the rules
    "font-size": {
      "hero":           { "value": "66px" },
      "hero-phone":     { "value": "49px" },
      "title":          { "value": "47px" },
      "title-phone":    { "value": "37px" },
      "h2":             { "value": "33px" },
      "h2-phone":       { "value": "28px" },
      "big":            { "value": "23px" },
      "big-phone":      { "value": "21px" },
      "base":           { "value": "16px" },
      "small":          { "value": "12px" }
    }
  }
}
